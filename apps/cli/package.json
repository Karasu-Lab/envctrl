{
  "name": "@envctrl/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "envctrl": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@envctrl/types": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
