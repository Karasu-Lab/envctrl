{
  "name": "@envctrl/cli",
  "version": "1.3.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "envctrl": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@envctrl/types": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
